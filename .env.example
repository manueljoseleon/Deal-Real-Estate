# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── Supabase / PostgreSQL ────────────────────────────────────────────────────
# Get this from: Supabase project → Settings → Database → Connection string
# Use the "URI" format (session mode, port 5432 for SQLAlchemy)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Development: leave empty (defaults to http://localhost:3000)
# Production:  set to your Vercel URL
CORS_ORIGINS=https://your-app.vercel.app

# ── App ──────────────────────────────────────────────────────────────────────
DEBUG=false

# ── Optional: ScraperAPI (fallback for Cloudflare-protected portals) ─────────
# SCRAPER_API_KEY=your_key_here
